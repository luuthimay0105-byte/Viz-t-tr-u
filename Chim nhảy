local function addDropdown(text, settingKey, options, yPos)
    local dropFrame = Instance.new("Frame")
    dropFrame.Size = UDim2.new(1, -20, 0, 35)
    dropFrame.Position = UDim2.new(0, 10, 0, yPos)
    dropFrame.BackgroundTransparency = 1
    dropFrame.Parent = mainFrame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = dropFrame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 100, 0, 30)
    btn.Position = UDim2.new(1, -110, 0, 2)
    btn.Text = Settings[settingKey]
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    btn.Parent = dropFrame
    
    local expanded = false
    local listFrame = nil
    btn.MouseButton1Click:Connect(function()
        if expanded then
            if listFrame then listFrame:Destroy() end
            expanded = false
            return
        end
        expanded = true
        listFrame = Instance.new("Frame")
        listFrame.Size = UDim2.new(0, 100, 0, #options * 25)
        listFrame.Position = UDim2.new(1, -110, 0, 30)
        listFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        listFrame.Parent = dropFrame
        for i, opt in pairs(options) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 25)
            optBtn.Position = UDim2.new(0, 0, 0, (i-1)*25)
            optBtn.Text = opt
            optBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
            optBtn.TextColor3 = Color3.fromRGB(255,255,255)
            optBtn.Parent = listFrame
            optBtn.MouseButton1Click:Connect(function()
                Settings[settingKey] = opt
                btn.Text = opt
                listFrame:Destroy()
                expanded = false
            end)
        end
    end)
    return dropFrame
end

