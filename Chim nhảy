    FarmRadius = 45,
    AttackDelay = 0.3,
    AutoRaid = false,
    RaidType = "Flame",
    AutoSea = false,
    SeaTarget = "SeaBeast",
    AutoFruit = true,
    FruitAction = "Store",
    AutoStats = true,
    StatPriority = "Melee",
    ESPEnabled = true,
    ESPFruit = true,
    ESPPlayer = false,
