-- ===== HÀM THÔNG BÁO VĨ SKY =====
local function showViSkyNotification()
    local screenGui = player:WaitForChild("PlayerGui"):FindFirstChild("ViSkyNotif")
    if screenGui then screenGui:Destroy() end
    
    local notifGui = Instance.new("ScreenGui")
    notifGui.Name = "ViSkyNotif"
    notifGui.Parent = player:WaitForChild("PlayerGui")
    notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 80)
    frame.Position = UDim2.new(0.5, -150, 0.2, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.3
    frame.BorderSizePixel = 0
    frame.Parent = notifGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.Text = "🔥 VĨ SKY 🔥"
    text.TextColor3 = Color3.fromRGB(255, 100, 0)
    text.BackgroundTransparency = 1
    text.Font = Enum.Font.GothamBold
    text.TextSize = 28
    text.TextScaled = true
    text.Parent = frame
    
    local glow = Instance.new("UIGradient")
    glow.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 150, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
    })
    glow.Rotation = 45
    glow.Parent = frame
    
    -- Hiệu ứng xuất hiện
    frame.BackgroundTransparency = 1
    text.TextTransparency = 1
    local tweenIn = tweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {BackgroundTransparency = 0.3})
    local tweenText = tweenService:Create(text, TweenInfo.new(0.3, Enum.EasingStyle.Back), {TextTransparency = 0})
    tweenIn:Play()
    tweenText:Play()
    
    -- Tự động ẩn sau 3 giây
    task.wait(3)
    local tweenOut = tweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 1})
    local tweenTextOut = tweenService:Create(text, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {TextTransparency = 1})
    tweenOut:Play()
    tweenTextOut:Play()
    tweenOut.Completed:Wait()
    notifGui:Destroy()
end

-- ===== GỌI THÔNG BÁO KHI BẬT SCRIPT =====
showViSkyNotification()

-- ===== HÀM TIỆN ÍCH =====
local function teleport(pos)
    if not player.Character then return end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if Settings.TeleportSmooth then
        local tween = tweenService:Create(hrp, TweenInfo.new(0.3, Enum.EasingStyle.Linear), {CFrame = CFrame.new(pos)})
        tween:Play()
        tween.Completed:Wait()
    else
        hrp.CFrame = CFrame.new(pos)
    end
end

local function getNearest(targetType)
    local nearest = nil
    local minDist = math.huge
    for _, v in pairs(workspace:GetDescendants()) do
        local check = false
        if targetType == "NPC" and v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Name ~= player.Name and not v:FindFirstChild("Player") then
            check = true
        elseif targetType == "Boss" and v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Name:find("Boss") then
            check = true
        elseif targetType == "Elite" and v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Name:find("Elite") then
            check = true
        elseif targetType == "SeaBeast" and v:IsA("Model") and v.Name:find("SeaBeast") and v:FindFirstChild("Humanoid") then
            check = true
        end
        if check then
            local humanoid = v:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local hrpChar = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrpChar then
                    local dist = (v:FindFirstChild("Head") or v:FindFirstChild("HumanoidRootPart")).Position - hrpChar.Position
                    local mag = dist.Magnitude
                    if mag < minDist then
                        minDist = mag
                        nearest = v
                    end
                end
            end
        end
    end
    return nearest, minDist
end

local function attack()
    local key = Enum.KeyCode.E
    if Settings.FarmTarget == "NPC" then
        key = Enum.KeyCode.E
    elseif Settings.FarmTarget == "Boss" then
        key = Enum.KeyCode.R
    end
    virtualInput:SendKeyEvent(true, key, false, game)
    task.wait(Settings.AttackDelay)
    virtualInput:SendKeyEvent(false, key, false, game)
end

-- ===== AUTO FARM =====
if Settings.AutoFarm then
    runService.RenderStepped:Connect(function()
        if not player.Character then return end
        local target, dist = getNearest(Settings.FarmTarget)
        if target and dist <= Settings.FarmRadius then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = target.Head.CFrame + Vector3.new(0, 2, 2)
                attack()
            end
        elseif target and dist > Settings.FarmRadius then
            teleport(target.Head.Position + Vector3.new(0, 2, 3))
        end
    end)
end

-- ===== AUTO RAID =====
if Settings.AutoRaid then
    local raidDoors = {
        Flame = Vector3.new(-495, 85, -590),
        Ice = Vector3.new(-476, 82, -644),
        Dark = Vector3.new(-542, 90, -623),
        Light = Vector3.new(-535, 95, -615),
        Sand = Vector3.new(-523, 88, -608),
        Magma = Vector3.new(-510, 86, -600),
        Human = Vector3.new(-487, 84, -655),
        Mink = Vector3.new(-468, 80, -667),
        Fishman = Vector3.new(-455, 78, -679),
        Skypiea = Vector3.new(-442, 76, -691)
    }
    local raidPos = raidDoors[Settings.RaidType]
    if raidPos then
        teleport(raidPos)
        task.wait(1)
        virtualInput:SendKeyEvent(true, Enum.KeyCode.T, false, game)
        task.wait(0.5)
        virtualInput:SendKeyEvent(false, Enum.KeyCode.T, false, game)
    end
end

-- ===== AUTO SEA EVENT =====
if Settings.AutoSea then
    runService.RenderStepped:Connect(function()
        local target, dist = getNearest(Settings.SeaTarget)
        if target and dist < 150 then
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = target.HumanoidRootPart.CFrame + Vector3.new(0, 5, 10)
                attack()
            end
        end
    end)
end

-- ===== AUTO FRUIT =====
if Settings.AutoFruit then
    if Settings.FruitAction == "Store" then
        for _, v in pairs(player.Backpack:GetChildren()) do
            if v:IsA("Tool") and v.Name:find("Fruit") then
                v.Parent = player.StarterGear
            end
        end
    elseif Settings.FruitAction == "Sell" then
        local fruitNPC = workspace:FindFirstChild("FruitSeller")
        if fruitNPC then
            teleport(fruitNPC.Head.Position)
            task.wait(1)
            virtualInput:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        end
    elseif Settings.FruitAction == "Roll" then
        local gacha = workspace:FindFirstChild("Gacha")
        if gacha then
            teleport(gacha.Head.Position)
            task.wait(1)
            virtualInput:SendKeyEvent(true, Enum.KeyCode.F, false, game)
        end
    end
end

-- ===== AUTO STATS =====
if Settings.AutoStats then
    local stats = player:FindFirstChild("Data") and player.Data:FindFirstChild("Stats")
    if stats then
        runService.RenderStepped:Connect(function()
            local statPoint = stats:FindFirstChild("StatPoints")
            if statPoint and statPoint.Value > 0 then
                local btn = player.PlayerGui:FindFirstChild("StatsGUI"):FindFirstChild(Settings.StatPriority)
                if btn then
                    for i = 1, statPoint.Value do
                        btn:FireServer()
                        task.wait(0.05)
                    end
                end
            end
        end)
    end
end

-- ===== ESP =====
if Settings.ESPEnabled then
    local function createESP(obj, color)
        local highlight = Instance.new("Highlight")
        highlight.Parent = obj
        highlight.FillColor = color
        highlight.OutlineColor = Color3.new(1,1,1)
        highlight.FillTransparency = 0.4
        highlight.Adornee = obj
        return highlight
    end
    
    for _, v in pairs(workspace:GetDescendants()) do
        if Settings.ESPFruit and v:IsA("Tool") and v.Name:find("Fruit") then
            createESP(v, Color3.fromRGB(255,0,255))
        elseif Settings.ESPPlayer and v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Name ~= player.Name then
            createESP(v, Color3.fromRGB(0,255,0))
        elseif Settings.ESPChest and v:IsA("BasePart") and v.Name:find("Chest") then
            createESP(v, Color3.fromRGB(255,255,0))
        elseif Settings.ESPNPC and v:IsA("Model") and v:FindFirstChild("Humanoid") and not v:FindFirstChild("Player") then
            createESP(v, Color3.fromRGB(255,128,0))
        end
    end
    
    workspace.DescendantAdded:Connect(function(d)
        if Settings.ESPFruit and d:IsA("Tool") and d.Name:find("Fruit") then
            createESP(d, Color3.fromRGB(255,0,255))
        elseif Settings.ESPPlayer and d:IsA("Model") and d:FindFirstChild("Humanoid") and d.Name ~= player.Name then
            createESP(d, Color3.fromRGB(0,255,0))
        elseif Settings.ESPChest and d:IsA("BasePart") and d.Name:find("Chest") then
            createESP(d, Color3.fromRGB(255,255,0))
        elseif Settings.ESPNPC and d:IsA("Model") and d:FindFirstChild("Humanoid") and not d:FindFirstChild("Player") then
            createESP(d, Color3.fromRGB(255,128,0))
        end
    end)
end

-- ===== MASTERY FARM =====
if Settings.MasteryFarm then
    runService.RenderStepped:Connect(function()
        local weapon = player.Character and player.Character:FindFirstChildWhichIsA("Tool")
        if weapon then
            local mastery = weapon:FindFirstChild("Mastery")
            if mastery then
                attack()
            end
        end
    end)
end

